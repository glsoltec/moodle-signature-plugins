<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/certificatesign/db" VERSION="20260701" COMMENT="XMLDB file for local_certificatesign">
  <TABLES>
    <TABLE NAME="local_certificatesign_log" COMMENT="Log of signed certificate issues">
      <FIELDS>
        <FIELD NAME="id"         TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="issueid"    TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="issueid" TYPE="unique"  FIELDS="issueid"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
